@using DotNetAdmin.Core.Data.Entities
@using DotNetAdmin.Modules.Access.Role.Dtos
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var result = (PaginationResult<Role>)ViewBag.Result;
    var filter = (RoleFilterDto)ViewBag.Filter;
    int rowNum = result.From;
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Role Management</h1>
</div>

<div class="tw-card p-0 overflow-hidden">
    <div class="px-6 py-4 border-b flex items-center justify-between">
        <h2 class="text-lg font-bold" style="color:var(--primary)">Role List</h2>
        <div class="btn-group btn-sm">
            <a href="@Url.RouteUrl("admin.v1.access.role.create")" class="btn btn-success btn-sm">
                <i class="fas fa-fw fa-plus"></i> Add Data
            </a>
            <button type="submit" form="selection" formmethod="post"
                    formaction="@Url.RouteUrl("admin.v1.access.role.delete_selected")?_method=DELETE"
                    data-confirm="Confirm Delete" class="btn btn-danger btn-sm">
                <i class="fas fa-fw fa-times"></i> Delete Selected
            </button>
        </div>
    </div>

    <div class="p-4" style="overflow-x:auto">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <form id="searchform" method="get" action="@Url.RouteUrl("admin.v1.access.role.index")">
                    <tr>
                        <th width="2%"></th>
                        <th width="7%">
                            <select name="q_page_size" id="q_page_size" class="form-control">
                                <option value="10" selected="@(filter.PageSize == 10)">10</option>
                                <option value="20" selected="@(filter.PageSize == 20)">20</option>
                                <option value="50" selected="@(filter.PageSize == 50)">50</option>
                                <option value="100" selected="@(filter.PageSize == 100)">100</option>
                            </select>
                        </th>
                        <th width="24%"><input id="q_name" type="text" class="form-control" name="q_name" value="@filter.QName"></th>
                        <th width="12%">
                            <select name="q_status" id="q_status" class="form-control">
                                <option disabled selected="@(string.IsNullOrEmpty(filter.QStatus))">Select</option>
                                <option value="Active" selected="@(filter.QStatus == "Active")">Active</option>
                                <option value="Inactive" selected="@(filter.QStatus == "Inactive")">Inactive</option>
                            </select>
                        </th>
                        <th width="13%"><input id="q_desc" type="text" class="form-control" name="q_desc" value="@filter.QDesc"></th>
                        <th width="5%" class="text-center align-middle">
                            <div class="btn-group">
                                <button type="submit" form="searchform" class="btn btn-sm btn-success"><i class="fas fa-fw fa-search"></i></button>
                                <a href="@Url.RouteUrl("admin.v1.access.role.index")" class="btn btn-sm btn-danger"><i class="fas fa-fw fa-times"></i></a>
                            </div>
                        </th>
                    </tr>
                    <tr>
                        <th width="5%"><input type="checkbox" id="checkall"/></th>
                        <th width="5%">No</th>
                        <th width="24%">Name</th>
                        <th width="15%">Status</th>
                        <th width="13%">Description</th>
                        <th width="5%">Action</th>
                    </tr>
                </form>
            </thead>
            <tbody>
                <form id="selection">
                    @Html.AntiForgeryToken()
                    @foreach (var role in result.Data)
                    {
                        <tr>
                            <td><input name="selected[]" value="@role.Id" type="checkbox"/></td>
                            <td>@rowNum</td>
                            <td>@role.Name</td>
                            <td class="text-left">
                                @if (role.Status == "Active")
                                {
                                    <i class="fas fa-check-circle text-green-500 text-xl" title="Active"></i>
                                }
                                else
                                {
                                    <i class="fas fa-times-circle text-red-500 text-xl" title="Inactive"></i>
                                }
                            </td>
                            <td>@role.Desc</td>
                            <td class="text-center">
                                <div class="btn-group">
                                    <button type="button" class="btn btn-sm btn-primary dropdown-toggle" data-toggle-dd aria-expanded="false">Action</button>
                                    <div class="dropdown-menu dropdown-menu-end">
                                        <a href="@Url.RouteUrl("admin.v1.access.role.permission.index", new { id = role.Id })" class="dropdown-item"><i class="fas fa-key fa-fw"></i> Permission</a>
                                        <a href="@Url.RouteUrl("admin.v1.access.role.edit", new { id = role.Id })" class="dropdown-item"><i class="fas fa-pen fa-fw"></i> Edit</a>
                                        <div class="dropdown-divider"></div>
                                        <form method="post" action="@Url.RouteUrl("admin.v1.access.role.delete", new { id = role.Id })?_method=DELETE" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" data-confirm="Confirm Delete" class="dropdown-item danger"><i class="fas fa-trash fa-fw"></i> Delete</button>
                                        </form>
                                    </div>
                                </div>
                            </td>
                        </tr>
                        rowNum++;
                    }
                    @if (!result.Data.Any())
                    {
                        <tr><td colspan="6" class="text-center text-gray-400 py-4">No data yet.</td></tr>
                    }
                </form>
            </tbody>
        </table>

        <div class="d-flex justify-content-end mt-4">
            <nav>
                <ul class="pagination">
                    @if (result.HasPrev)
                    {
                        <li class="page-item"><a class="page-link" href="@Url.RouteUrl("admin.v1.access.role.index", new { q_name = filter.QName, q_status = filter.QStatus, q_desc = filter.QDesc, q_page_size = filter.PageSize, Page = result.Page - 1 })">Previous</a></li>
                    }
                    @for (int p = 1; p <= result.TotalPages; p++)
                    {
                        <li class="page-item @(p == result.Page ? "active" : "")"><a class="page-link" href="@Url.RouteUrl("admin.v1.access.role.index", new { q_name = filter.QName, q_status = filter.QStatus, q_desc = filter.QDesc, q_page_size = filter.PageSize, Page = p })">@p</a></li>
                    }
                    @if (result.HasNext)
                    {
                        <li class="page-item"><a class="page-link" href="@Url.RouteUrl("admin.v1.access.role.index", new { q_name = filter.QName, q_status = filter.QStatus, q_desc = filter.QDesc, q_page_size = filter.PageSize, Page = result.Page + 1 })">Next</a></li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>

<script>
    $("#checkall").click(function(){ $('input:checkbox').not(this).prop('checked', this.checked); });
</script>

@{
    Layout = "_FullWidthLayout";
    ViewBag.Title = "Forgot Password";
}

<div class="w-full max-w-md mx-auto">
    <div class="tw-card overflow-hidden">
        <div class="px-4 py-6 text-center text-white" style="background:linear-gradient(135deg,var(--theme-dark) 0%,var(--primary) 100%)">
            <div class="w-16 h-16 rounded-2xl bg-white/20 flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-key text-3xl"></i>
            </div>
            <h1 class="text-xl font-bold">Forgot Password</h1>
            <p class="text-white/70 text-sm mt-1">Enter your Email to continue</p>
        </div>
        <div class="px-8 py-8">
            @if (ViewBag.FlashKey != null) {
            <div class="alert @(ViewBag.FlashKey == "error" ? "alert-danger" : "alert-success") mb-5">
                @ViewBag.FlashMessage
            </div>
            }
            <form action="/admin/v1/auth/reset/request" method="POST" class="space-y-5">
                @Html.AntiForgeryToken()
                <div>
                    <label class="form-label">Email address</label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><i class="fas fa-envelope"></i></span>
                        <input name="email" type="email" class="form-control pl-9" placeholder="you@example.com" required autofocus>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary-tw w-full py-2.5 font-semibold">
                    <i class="fas fa-paper-plane"></i> Send OTP
                </button>
            </form>
            <p class="text-center text-sm text-gray-500 mt-6">
                <a href="/auth/login" class="no-underline hover:underline" style="color:var(--primary)">back?</a>
            </p>
        </div>
    </div>
</div>

@{
    Layout = "_FullWidthLayout";
    ViewBag.Title = "Reset Password";
}

<div class="w-full max-w-md mx-auto">
    <div class="tw-card overflow-hidden">
        <div class="px-4 py-6 text-center text-white" style="background:linear-gradient(135deg,var(--theme-dark) 0%,var(--primary) 100%)">
            <div class="w-16 h-16 rounded-2xl bg-white/20 flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-lock-open text-3xl"></i>
            </div>
            <h1 class="text-xl font-bold">Reset Password</h1>
            <p class="text-white/70 text-sm mt-1">Enter Your New Password</p>
        </div>
        <div class="px-8 py-8">
            @if (ViewBag.FlashKey != null) {
            <div class="alert @(ViewBag.FlashKey == "error" ? "alert-danger" : "alert-success") mb-5">
                @ViewBag.FlashMessage
            </div>
            }
            <form action="/admin/v1/auth/reset/process" method="POST" class="space-y-5">
                @Html.AntiForgeryToken()
                <div>
                    <label class="form-label">Email</label>
                    <input name="email" type="email" class="form-control" placeholder="you@example.com" required>
                </div>
                <div>
                    <label class="form-label">OTP Code</label>
                    <input name="otp" type="text" class="form-control" placeholder="6-digit OTP" maxlength="6"
                           autocomplete="one-time-code" value="@ViewBag.OldOtp" required>
                </div>
                <div>
                    <label class="form-label">New Password</label>
                    <input name="password" type="password" class="form-control" placeholder="Min. 8 chars" required>
                </div>
                <div>
                    <label class="form-label">Confirm New Password</label>
                    <input name="passwordConfirm" type="password" class="form-control" placeholder="••••••••" required>
                </div>
                <button type="submit" class="btn btn-primary-tw w-full py-2.5 font-semibold">
                    <i class="fas fa-check"></i> Reset Password
                </button>
            </form>
            <p class="text-center text-sm text-gray-500 mt-6">
                <a href="/admin/v1/auth/reset/req" class="no-underline hover:underline" style="color:var(--primary)">back?</a>
            </p>
        </div>
    </div>
</div>

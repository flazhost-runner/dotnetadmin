<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>@ViewBag.Title - @(ViewBag.AppName ?? "DotNetAdmin")</title>
    @{
        var _af = Context.RequestServices.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>();
        var _tok = _af?.GetAndStoreTokens(Context);
    }
    <meta name="csrf-token" content="@_tok?.RequestToken">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '@(ViewBag.ThemePrimary ?? "#3B82F6")',
                        secondary: '@(ViewBag.ThemeSecondary ?? "#60A5FA")',
                        'theme-light': '@(ViewBag.ThemeLight ?? "#DBEAFE")',
                        'theme-dark': '@(ViewBag.ThemeDark ?? "#1E40AF")'
                    }
                }
            }
        }
    </script>
    <style type="text/tailwindcss">
        @@layer components {
            .form-control { @@apply block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-800 focus:outline-none focus:ring-2 focus:border-transparent; }
            .form-control:focus { --tw-ring-color: var(--primary); }
            .form-control.is-invalid { @@apply border-red-500 focus:ring-red-400; }
            select.form-control { @@apply bg-white; }
            .form-label { @@apply block mb-1 text-sm text-gray-700; }
            .form-check-input { @@apply w-4 h-4 rounded border-gray-300 align-middle; accent-color: var(--primary); }
            .form-check-label { @@apply ml-1 text-sm text-gray-700; }
            .invalid-feedback { @@apply block mt-1 text-sm text-red-600; }
            .btn { @@apply inline-flex items-center justify-center gap-1 rounded-lg px-4 py-2 text-sm font-medium cursor-pointer transition-colors border-0 no-underline; }
            .btn-sm { @@apply px-3 py-1.5 text-xs; }
            .btn-primary, .btn-primary-tw { background: var(--primary); @@apply text-white; }
            .btn-primary:hover, .btn-primary-tw:hover { background: var(--theme-dark); @@apply text-white; }
            .btn-success { @@apply bg-green-600 text-white hover:bg-green-700; }
            .btn-danger { @@apply bg-red-600 text-white hover:bg-red-700; }
            .alert { @@apply rounded-lg px-4 py-3 mb-4 text-sm border; }
            .alert-danger { @@apply bg-red-50 text-red-700 border-red-200; }
            .alert-success { @@apply bg-green-50 text-green-700 border-green-200; }
            .alert-info { @@apply bg-blue-50 text-blue-700 border-blue-200; }
        }
        :root {
            --primary: @(ViewBag.ThemePrimary ?? "#3B82F6");
            --secondary: @(ViewBag.ThemeSecondary ?? "#60A5FA");
            --theme-light: @(ViewBag.ThemeLight ?? "#DBEAFE");
            --theme-dark: @(ViewBag.ThemeDark ?? "#1E40AF");
        }
        .tw-card { @@apply bg-white rounded-2xl; box-shadow: 0 10px 25px -5px rgba(0,0,0,.08), 0 8px 10px -6px rgba(0,0,0,.05); }
        .sidebar-gradient { background: var(--theme-dark); }
        .text-primary-tw { color: var(--primary) !important; }
        .text-decoration-none { text-decoration: none; }
        .d-flex { display: flex; }
        .justify-content-between { justify-content: space-between; }
        .fw-semibold { font-weight: 600; }
        .fw-bold { font-weight: 700; }
        .w-100 { width: 100%; }
        .small { font-size: .875rem; }
        .mb-0 { margin-bottom: 0; }
        .mb-3 { margin-bottom: .75rem; }
        .mb-6 { margin-bottom: 1.5rem; }
        .mb-8 { margin-bottom: 2rem; }
        .my-4 { margin-top: 1rem; margin-bottom: 1rem; }
    </style>
    <link href="/be/default/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    @RenderSection("Styles", required: false)
</head>
<body class="min-h-screen flex items-center justify-center p-4" style="background: linear-gradient(135deg, var(--theme-light) 0%, #f8fafc 100%);">
    @RenderBody()

    <div class="toast-container" id="tw-toasts" style="position:fixed;top:1rem;right:1rem;z-index:70;display:flex;flex-direction:column;gap:.5rem;"></div>
    <script>
        window.Toast = function(message, type) {
            type = type || 'info';
            var c = document.getElementById('tw-toasts');
            var t = document.createElement('div');
            t.style.cssText = 'min-width:16rem;max-width:22rem;background:#fff;border-radius:.75rem;padding:.75rem 1rem;box-shadow:0 10px 25px -5px rgba(0,0,0,.18);border-left:4px solid var(--primary);display:flex;align-items:center;gap:.6rem;font-size:.9rem;transform:translateX(120%);transition:transform .25s ease,opacity .25s ease;opacity:0;';
            if(type==='success') t.style.borderLeftColor='#16a34a';
            if(type==='error') t.style.borderLeftColor='#dc2626';
            var icon = type==='success'?'fa-check-circle':type==='error'?'fa-times-circle':'fa-info-circle';
            t.innerHTML = '<i class="fas '+icon+'"></i><span>'+message+'</span>';
            c.appendChild(t);
            requestAnimationFrame(function(){ t.style.transform='translateX(0)'; t.style.opacity='1'; });
            setTimeout(function(){ t.style.transform='translateX(120%)'; t.style.opacity='0'; setTimeout(function(){ t.remove(); }, 300); }, 3500);
        };
        @if (ViewBag.FlashKey != null) {
            <text>document.addEventListener('DOMContentLoaded', function() { Toast('@Html.Raw(ViewBag.FlashMessage)', '@ViewBag.FlashKey'); });</text>
        }
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>

@{
    Layout = null;
    var setting = ViewBag.Setting as DotNetAdmin.Core.Data.Entities.Setting;
    var siteName = setting?.Name ?? "DotNetAdmin";
    var description = setting?.Description ?? "A powerful admin panel built with ASP.NET Core";
    var logoUrl = setting?.Logo ?? "/media/setting/login-image.png";
    var phone = setting?.Phone ?? "+1 234 567 890";
    var email = setting?.Email ?? "hello@example.com";
    var address = setting?.Address ?? "123 Main Street, City, Country";
    var copyright = setting?.Copyright ?? $"© {DateTime.Now.Year} {siteName}. All rights reserved.";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@siteName</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        html { scroll-behavior: smooth; }
        .hero-gradient { background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 50%, #06b6d4 100%); }
        .card-hover { transition: transform .2s, box-shadow .2s; }
        .card-hover:hover { transform: translateY(-4px); box-shadow: 0 20px 40px rgba(0,0,0,.12); }
        .masonry { columns: 2; column-gap: 1rem; }
        @@media (min-width: 768px) { .masonry { columns: 3; } }
        .masonry-item { break-inside: avoid; margin-bottom: 1rem; }
    </style>
</head>
<body class="bg-white text-slate-800">

@* ── Navbar ── *@
<nav class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-slate-100 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-3">
            <img src="@logoUrl" alt="logo" class="h-8 w-8 rounded object-cover">
            <span class="text-lg font-bold text-blue-700">@siteName</span>
        </a>
        <div class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-600">
            <a href="#hero" class="hover:text-blue-600 transition-colors">Home</a>
            <a href="#services" class="hover:text-blue-600 transition-colors">Services</a>
            <a href="#about" class="hover:text-blue-600 transition-colors">About</a>
            <a href="#contact" class="hover:text-blue-600 transition-colors">Contact</a>
        </div>
        <a href="/auth/login" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            Admin Login
        </a>
    </div>
</nav>

@* ── Hero ── *@
<section id="hero" class="hero-gradient min-h-screen flex items-center justify-center text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
        <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-white rounded-full blur-3xl"></div>
        <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-cyan-300 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 text-center py-24">
        <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur rounded-full px-4 py-2 text-sm font-medium mb-6">
            <i class="fas fa-star text-yellow-300"></i>
            <span>Powered by ASP.NET Core 10 LTS</span>
        </div>
        <h1 class="text-5xl md:text-7xl font-black mb-6 leading-tight">@siteName</h1>
        <p class="text-xl md:text-2xl text-blue-100 mb-10 max-w-2xl mx-auto">@Html.Raw(description)</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/auth/login" class="bg-white text-blue-700 font-bold px-8 py-4 rounded-xl hover:bg-blue-50 transition-colors shadow-lg">
                <i class="fas fa-rocket mr-2"></i>Get Started
            </a>
            <a href="#services" class="border-2 border-white/50 text-white font-bold px-8 py-4 rounded-xl hover:bg-white/10 transition-colors">
                <i class="fas fa-play mr-2"></i>Learn More
            </a>
        </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <i class="fas fa-chevron-down text-white/60 text-2xl"></i>
    </div>
</section>

@* ── Stats ── *@
<section class="py-16 bg-slate-50 border-b border-slate-100">
    <div class="max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
            <div>
                <div class="text-4xl font-black text-blue-600 counter-val" data-target="100">0</div>
                <div class="text-slate-500 text-sm mt-1">Happy Clients</div>
            </div>
            <div>
                <div class="text-4xl font-black text-blue-600 counter-val" data-target="500">0</div>
                <div class="text-slate-500 text-sm mt-1">Projects Done</div>
            </div>
            <div>
                <div class="text-4xl font-black text-blue-600 counter-val" data-target="24">0</div>
                <div class="text-slate-500 text-sm mt-1">Support Hours</div>
            </div>
            <div>
                <div class="text-4xl font-black text-blue-600 counter-val" data-target="99">0</div>
                <div class="text-slate-500 text-sm mt-1">% Uptime</div>
            </div>
        </div>
    </div>
</section>

@* ── Services ── *@
<section id="services" class="py-24">
    <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-14">
            <h2 class="text-4xl font-black text-slate-800 mb-4">Our Services</h2>
            <p class="text-slate-500 max-w-xl mx-auto">Everything you need to build and manage your application</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @{
                var services = new[] {
                    (icon:"fas fa-shield-halved", title:"Security", desc:"Role-based access control with granular permissions"),
                    (icon:"fas fa-users", title:"User Management", desc:"Complete user lifecycle management with audit trails"),
                    (icon:"fas fa-chart-line", title:"Analytics", desc:"Real-time dashboard with charts and insights"),
                    (icon:"fas fa-palette", title:"Theming", desc:"9 built-in themes with live preview switching"),
                    (icon:"fas fa-bolt", title:"Performance", desc:"Optimized queries, caching, and response compression"),
                    (icon:"fas fa-code", title:"API Ready", desc:"RESTful JSON API with JWT authentication"),
                };
            }
            @foreach (var svc in services)
            {
                <div class="card-hover bg-white rounded-2xl p-8 border border-slate-100 shadow-sm">
                    <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center mb-5">
                        <i class="@svc.icon text-2xl text-blue-600"></i>
                    </div>
                    <h3 class="text-xl font-bold text-slate-800 mb-3">@svc.title</h3>
                    <p class="text-slate-500 leading-relaxed">@svc.desc</p>
                </div>
            }
        </div>
    </div>
</section>

@* ── Feature (2-col) ── *@
<section class="py-24 bg-blue-50">
    <div class="max-w-7xl mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-16 items-center">
            <div>
                <span class="text-blue-600 font-semibold text-sm uppercase tracking-widest">Why Choose Us</span>
                <h2 class="text-4xl font-black text-slate-800 mt-3 mb-6">Built for developers,<br>loved by teams</h2>
                <ul class="space-y-4 text-slate-600">
                    <li class="flex items-start gap-3"><i class="fas fa-check-circle text-blue-500 mt-1 shrink-0"></i><span>Vertical Slice Architecture — clean module boundaries</span></li>
                    <li class="flex items-start gap-3"><i class="fas fa-check-circle text-blue-500 mt-1 shrink-0"></i><span>EF Core 10 with multi-DB support (SQLite/MySQL/Postgres)</span></li>
                    <li class="flex items-start gap-3"><i class="fas fa-check-circle text-blue-500 mt-1 shrink-0"></i><span>xUnit + Testcontainers for real integration tests</span></li>
                    <li class="flex items-start gap-3"><i class="fas fa-check-circle text-blue-500 mt-1 shrink-0"></i><span>Cookie + JWT dual-auth for web &amp; API consumers</span></li>
                </ul>
                <a href="/auth/login" class="inline-flex items-center gap-2 mt-8 bg-blue-600 text-white font-semibold px-6 py-3 rounded-xl hover:bg-blue-700 transition-colors">
                    Start now <i class="fas fa-arrow-right"></i>
                </a>
            </div>
            <div class="relative">
                <div class="bg-white rounded-2xl shadow-2xl p-2 border border-slate-100">
                    <img src="@logoUrl" alt="feature" class="w-full h-80 object-cover rounded-xl">
                </div>
                <div class="absolute -top-4 -right-4 bg-blue-600 text-white rounded-xl p-4 shadow-lg">
                    <i class="fas fa-rocket text-2xl"></i>
                </div>
            </div>
        </div>
    </div>
</section>

@* ── Masonry Gallery ── *@
<section class="py-24">
    <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-14">
            <h2 class="text-4xl font-black text-slate-800 mb-4">Gallery</h2>
            <p class="text-slate-500">Visual showcase of our work</p>
        </div>
        <div class="masonry">
            @{
                var galleryColors = new[] { "bg-blue-100", "bg-indigo-100", "bg-cyan-100", "bg-slate-100", "bg-sky-100", "bg-teal-100" };
                var galleryIcons = new[] { "fa-image", "fa-photo-film", "fa-camera", "fa-film", "fa-images", "fa-panorama" };
                var galleryHeights = new[] { "h-48", "h-64", "h-56", "h-72", "h-48", "h-60" };
            }
            @for (int i = 0; i < 6; i++)
            {
                <div class="masonry-item card-hover rounded-2xl overflow-hidden @galleryColors[i % galleryColors.Length] @galleryHeights[i % galleryHeights.Length] flex items-center justify-center">
                    <i class="fas @galleryIcons[i % galleryIcons.Length] text-5xl text-slate-400"></i>
                </div>
            }
        </div>
    </div>
</section>

@* ── About Bento ── *@
<section id="about" class="py-24 bg-slate-800 text-white">
    <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-14">
            <h2 class="text-4xl font-black mb-4">About Us</h2>
            <p class="text-slate-400 max-w-xl mx-auto">@Html.Raw(description)</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="col-span-2 bg-blue-600 rounded-2xl p-8 flex flex-col justify-between min-h-48">
                <i class="fas fa-building-columns text-4xl text-blue-200 mb-4"></i>
                <div>
                    <h3 class="text-2xl font-black mb-2">Our Story</h3>
                    <p class="text-blue-100 text-sm">Born from the need for a clean, maintainable admin scaffold that teams can actually extend.</p>
                </div>
            </div>
            <div class="bg-slate-700 rounded-2xl p-6 flex flex-col justify-between min-h-36">
                <i class="fas fa-code text-2xl text-slate-400 mb-3"></i>
                <div><div class="text-3xl font-black text-white">10+</div><div class="text-slate-400 text-sm">Years C# Dev</div></div>
            </div>
            <div class="bg-slate-700 rounded-2xl p-6 flex flex-col justify-between min-h-36">
                <i class="fas fa-globe text-2xl text-slate-400 mb-3"></i>
                <div><div class="text-3xl font-black text-white">50+</div><div class="text-slate-400 text-sm">Countries</div></div>
            </div>
            <div class="bg-indigo-600 rounded-2xl p-6 flex flex-col justify-center min-h-36">
                <i class="fas fa-heart text-2xl text-indigo-200 mb-2"></i>
                <div class="text-sm text-indigo-100">Open Source &amp; MIT Licensed</div>
            </div>
            <div class="bg-slate-700 rounded-2xl p-6 flex flex-col justify-center min-h-36">
                <i class="fas fa-users text-2xl text-slate-400 mb-2"></i>
                <div class="text-sm text-slate-300">Community Driven</div>
            </div>
        </div>
    </div>
</section>

@* ── Testimonials ── *@
<section class="py-24">
    <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-14">
            <h2 class="text-4xl font-black text-slate-800 mb-4">What People Say</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
            @{
                var testimonials = new[] {
                    (name:"Alex Chen", role:"Backend Engineer", text:"Clean architecture, great DI patterns. Saved us weeks of boilerplate."),
                    (name:"Maria Santos", role:"Team Lead", text:"The RBAC system is exactly what we needed. Permission sync from routes is genius."),
                    (name:"David Park", role:"CTO", text:"Multi-DB support out of the box. Migrated from SQLite to Postgres with zero code changes."),
                };
            }
            @foreach (var t in testimonials)
            {
                <div class="card-hover bg-white rounded-2xl p-8 border border-slate-100 shadow-sm">
                    <div class="flex gap-1 mb-4">
                        @for (int s = 0; s < 5; s++) { <i class="fas fa-star text-yellow-400 text-sm"></i> }
                    </div>
                    <p class="text-slate-600 mb-6 leading-relaxed italic">"@t.text"</p>
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center">
                            <span class="text-blue-700 font-bold text-sm">@t.name[0]</span>
                        </div>
                        <div>
                            <div class="font-bold text-slate-800 text-sm">@t.name</div>
                            <div class="text-slate-400 text-xs">@t.role</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@* ── CTA ── *@
<section class="py-24 hero-gradient text-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="text-4xl font-black mb-5">Ready to get started?</h2>
        <p class="text-blue-100 mb-10 text-lg">Jump into the admin panel and explore all features.</p>
        <a href="/auth/login" class="inline-flex items-center gap-2 bg-white text-blue-700 font-bold px-10 py-4 rounded-xl hover:bg-blue-50 transition-colors shadow-lg text-lg">
            <i class="fas fa-rocket"></i> Launch Admin Panel
        </a>
    </div>
</section>

@* ── Footer ── *@
<footer id="contact" class="bg-slate-900 text-slate-400 py-16">
    <div class="max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-10">
            <div class="md:col-span-2">
                <div class="flex items-center gap-3 mb-4">
                    <img src="@logoUrl" alt="logo" class="h-8 w-8 rounded object-cover">
                    <span class="text-white font-bold text-lg">@siteName</span>
                </div>
                <p class="text-sm leading-relaxed mb-4">@Html.Raw(description)</p>
                <div class="flex gap-3">
                    <a href="#" class="w-9 h-9 rounded-lg bg-slate-800 hover:bg-blue-600 flex items-center justify-center transition-colors"><i class="fab fa-github text-sm"></i></a>
                    <a href="#" class="w-9 h-9 rounded-lg bg-slate-800 hover:bg-blue-600 flex items-center justify-center transition-colors"><i class="fab fa-twitter text-sm"></i></a>
                    <a href="#" class="w-9 h-9 rounded-lg bg-slate-800 hover:bg-blue-600 flex items-center justify-center transition-colors"><i class="fab fa-linkedin text-sm"></i></a>
                </div>
            </div>
            <div>
                <h4 class="text-white font-bold mb-4">Quick Links</h4>
                <ul class="space-y-2 text-sm">
                    <li><a href="#hero" class="hover:text-white transition-colors">Home</a></li>
                    <li><a href="#services" class="hover:text-white transition-colors">Services</a></li>
                    <li><a href="#about" class="hover:text-white transition-colors">About</a></li>
                    <li><a href="/auth/login" class="hover:text-white transition-colors">Admin Login</a></li>
                </ul>
            </div>
            <div>
                <h4 class="text-white font-bold mb-4">Contact</h4>
                <ul class="space-y-2 text-sm">
                    <li class="flex items-center gap-2"><i class="fas fa-phone text-blue-400 w-4"></i>@phone</li>
                    <li class="flex items-center gap-2"><i class="fas fa-envelope text-blue-400 w-4"></i>@email</li>
                    <li class="flex items-start gap-2"><i class="fas fa-location-dot text-blue-400 w-4 mt-0.5"></i>@address</li>
                </ul>
            </div>
        </div>
        <div class="border-t border-slate-800 pt-6 text-center text-sm">@copyright</div>
    </div>
</footer>

<script>
(function() {
    var observed = false;
    function animate() {
        document.querySelectorAll('.counter-val').forEach(function(el) {
            var target = parseInt(el.getAttribute('data-target')) || 0;
            var start = 0;
            var step = Math.max(1, Math.ceil(target / 60));
            var timer = setInterval(function() {
                start += step;
                if (start >= target) { el.textContent = target.toLocaleString(); clearInterval(timer); }
                else { el.textContent = start.toLocaleString(); }
            }, 20);
        });
    }
    var first = document.querySelector('.counter-val');
    if (first) {
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(e) {
                if (e.isIntersecting && !observed) { observed = true; animate(); }
            });
        }, { threshold: 0.3 });
        observer.observe(first);
    }
})();
</script>
</body>
</html>

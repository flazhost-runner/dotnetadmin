# DotNetAdmin Environment — copy to appsettings.Development.json or use user secrets
# dotnet user-secrets set "App:JwtSecret" "your-secret-here"

# App
App__SessionSecret=change-me-in-production-min-32-chars
App__JwtSecret=change-me-in-production-min-32-chars
App__JwtExpiresIn=1h
App__BcryptRounds=10
App__OtpExpiryMinutes=10
App__DefaultPageSize=10
App__SessionTtlHours=6
App__Mode=full

# Database (sqlite | mysql | postgres)
Database__Type=sqlite
Database__ConnectionString=Data Source=dotnetadmin.db
# Database__MySql=Server=localhost;Database=dotnetadmin;User=root;Password=secret;
# Database__Postgres=Host=localhost;Database=dotnetadmin;Username=postgres;Password=secret;

# Redis (NodeAdmin standard: redis://host:port URL format)
Redis__Url=redis://127.0.0.1:6379

# Session storage driver: database | redis | memory  (default: database)
# - redis    : simpan sesi di Redis. Cepat; sesi hilang saat Redis restart.
# - database : simpan sesi di DB utama (persist lintas container restart).
# - memory   : in-process; hanya untuk dev/single-node, hilang saat restart.
Session__Driver=database

# Storage (NodeAdmin standard STORAGE_* names)
Storage__Driver=local
Storage__BasePath=storage
Storage__Ssl=false
# Storage__Driver=oss
# Storage__Endpoint=https://oss-region.aliyuncs.com
# Storage__Bucket=your-bucket
# Storage__AccessKey=your-access-key
# Storage__SecretKey=your-secret-key
# Storage__Region=ap-southeast-5
# Storage__BaseUrl=https://your-bucket.oss-region.aliyuncs.com

# Email
Email__Host=smtp.gmail.com
Email__Port=587
Email__User=your@email.com
Email__Password=yourpassword
Email__From=noreply@dotnetadmin.com
Email__Secure=false
Email__FromName=NodeAdmin
